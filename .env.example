# RIDLY Mobile - Environment Configuration
# Copy this file to .env and update values for your environment

# Magento Backend URL (with /graphql endpoint)
# Default: RIDLY Magento 2 demo
# For production: use your own Magento instance URL
MAGENTO_URL=https://magento.ridly.io/graphql

# CORS Proxy Settings (for web development)
PROXY_PORT=3001

# Store Configuration
STORE_CODE=default

# Development
# Set to 'true' to enable debug logging
DEBUG=false
