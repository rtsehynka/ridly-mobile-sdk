{
  "$schema": "../../packages/core/ridly.mobile.schema.json",
  "store": {
    "platform": "magento",
    "url": "https://voriagh.gomage.dev",
    "graphql": true,
    "storeCode": "default"
  },
  "app": {
    "name": "RIDLY Demo",
    "bundleId": "com.ridly.demo",
    "packageName": "com.ridly.demo",
    "version": "1.0.0",
    "buildNumber": "1"
  },
  "theme": {
    "preset": "minimal",
    "colors": {
      "primary": "#000000",
      "primaryDark": "#1A1A1A",
      "secondary": "#666666",
      "secondaryDark": "#444444",
      "accent": "#000000",
      "background": "#FFFFFF",
      "surface": "#FAFAFA",
      "text": "#000000",
      "textSecondary": "#888888",
      "border": "#EEEEEE",
      "error": "#E53935",
      "success": "#43A047",
      "warning": "#FB8C00",
      "onPrimary": "#FFFFFF",
      "headerBackground": "#FFFFFF",
      "headerText": "#000000",
      "tabBarBackground": "#FFFFFF",
      "tabBarActive": "#000000",
      "tabBarInactive": "#AAAAAA",
      "disabled": "#F5F5F5",
      "disabledText": "#CCCCCC",
      "price": "#000000",
      "sale": "#E53935"
    },
    "darkMode": {
      "enabled": true,
      "auto": true,
      "colors": {
        "background": "#0A0A0A",
        "surface": "#141414",
        "text": "#FFFFFF",
        "textSecondary": "#999999",
        "border": "#2A2A2A",
        "headerBackground": "#0A0A0A",
        "headerText": "#FFFFFF",
        "tabBarBackground": "#0A0A0A",
        "primary": "#FFFFFF",
        "onPrimary": "#000000",
        "price": "#FFFFFF"
      }
    },
    "typography": {
      "fontFamily": "System",
      "headingFontFamily": "System",
      "baseFontSize": 15,
      "headingWeight": "600",
      "bodyWeight": "400"
    },
    "borderRadius": {
      "small": 4,
      "medium": 6,
      "large": 8,
      "button": 6,
      "card": 0,
      "image": 4
    },
    "spacing": {
      "screenPadding": 16,
      "cardPadding": 16,
      "sectionGap": 24
    }
  },
  "homeScreen": {
    "sections": [
      { "type": "banner", "enabled": false },
      { "type": "categories", "enabled": true, "title": "Categories", "style": "horizontal", "limit": 8 },
      { "type": "featured", "enabled": true, "title": "Featured Products", "limit": 10, "style": "carousel" },
      { "type": "newArrivals", "enabled": true, "title": "New Arrivals", "limit": 10, "style": "grid" },
      { "type": "onSale", "enabled": true, "title": "On Sale", "limit": 10, "style": "carousel" }
    ]
  },
  "product": {
    "gridColumns": 2,
    "showSku": false,
    "showStock": true,
    "showRating": false,
    "showWishlist": true,
    "showShare": false,
    "showRelated": true,
    "imageAspectRatio": "1:1",
    "galleryStyle": "scroll"
  },
  "features": {
    "wishlist": true,
    "search": true,
    "filters": true,
    "reviews": false,
    "guestCheckout": true,
    "socialLogin": {
      "google": false,
      "apple": true,
      "facebook": false
    },
    "pushNotifications": false,
    "deepLinking": true,
    "analytics": {
      "enabled": false,
      "provider": "none",
      "trackScreenViews": true,
      "trackAddToCart": true,
      "trackPurchase": true
    },
    "biometricLogin": false,
    "barcodeScan": false
  },
  "localization": {
    "defaultLanguage": "en",
    "languages": ["en", "fr"],
    "rtl": false,
    "currency": {
      "code": "EUR",
      "symbol": "€",
      "position": "before",
      "decimalSeparator": ".",
      "thousandSeparator": ",",
      "decimalDigits": 2
    }
  },
  "checkout": {
    "webViewCheckout": false,
    "webViewPaymentOnly": false,
    "requirePhone": true,
    "requireRegion": true,
    "defaultCountry": "FR"
  },
  "navigation": {
    "tabs": [
      { "name": "Home", "icon": "home" },
      { "name": "Categories", "icon": "grid" },
      { "name": "Cart", "icon": "shopping-bag", "showBadge": true },
      { "name": "Account", "icon": "user" }
    ],
    "drawer": {
      "enabled": false,
      "showCategories": true,
      "customLinks": []
    }
  }
}
